# ==============================================
# R CELL Management System - Environment Template
# ==============================================
# Copy file ini ke .env untuk development local,
# atau set di Vercel Dashboard untuk production.
# ==============================================

# ----- Database (PostgreSQL) -----
# Dapatkan dari Neon: https://neon.tech → buat project → copy connection string
# Format: postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/rcms?sslmode=require"

# ----- Optional -----
# NODE_ENV akan di-set otomatis oleh Vercel
# (production saat deploy, development saat npm run dev)
